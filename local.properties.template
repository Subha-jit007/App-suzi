# local.properties — NEVER commit this to Git!
# Add to .gitignore: local.properties
# ═══════════════════════════════════════════════════

# Android SDK path (set automatically by Android Studio)
sdk.dir=/Users/YourName/Library/Android/sdk

# ─── API KEYS (stored securely — not hardcoded in code) ───
# Get Claude key: https://console.anthropic.com → API Keys
CLAUDE_API_KEY=sk-ant-api03-YOUR_KEY_HERE

# Get Stability key: https://dreamstudio.ai/account
# (optional — for AI image generation)
STABILITY_API_KEY=sk-YOUR_STABILITY_KEY_HERE
